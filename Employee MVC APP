} 
body { 
    font-family: 'Segoe UI', sans-serif; 
    background: linear-gradient(135deg, #1f1c2c, #928dab); 
    height: 100vh; 
 
    display: flex; 
    justify-content: center; 
    align-items: center; 
 
    color: white; 
} 
.container { 
    background: rgba(255, 255, 255, 0.1); 
    padding: 30px; 
    border-radius: 15px; 
    backdrop-filter: blur(10px); 
    width: 320px; 
    text-align: center; 
 
    box-shadow: 0 10px 25px rgba(0,0,0,0.4); 
} 
h2 { 
    margin-bottom: 15px; 
} 
input { 
    width: 100%; 
    padding: 10px; 
    margin: 8px 0; 
 
    border: none; 
    border-radius: 8px; 
    outline: none; 
 
    transition: 0.3s; 
} 
input:hover, 
input:focus { 
    transform: scale(1.05); 
    box-shadow: 0 0 8px #00f7ff; 
} 
button { 
    width: 100%; 
    padding: 10px; 
    margin-top: 10px; 
 
    background: #00c6ff; 
    border: none; 
    border-radius: 10px; 
 
    color: white; 
    font-weight: bold; 
    cursor: pointer; 
 
    transition: 0.3s; 
} 
button:hover { 
    background: #0072ff; 
    transform: scale(1.05); 
} 
ul { 
    list-style: none; 
    margin-top: 15px; 
} 
li { 
    background: rgba(255,255,255,0.15); 
    padding: 8px; 
    margin: 5px 0; 
    border-radius: 6px; 
 
    transition: 0.3s; 
} 
li:hover { 
